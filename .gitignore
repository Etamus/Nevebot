# Ambiente virtual
venv/
.venv/

# Variáveis de ambiente (contém o token)
.env

# Modelos (arquivos GGUF/ONNX/BIN são muito grandes para commitar)
# Ignora modelos em qualquer subpasta dentro de models/
models/
models/**/*.gguf
models/**/*.bin
models/**/*.onnx
# Diretórios específicos de engines/voz que podem conter arquivos grandes
# Arquivos de áudio e gravações geradas (voz de referência, gravações temporárias)
data/*.wav
gravacoes/*.wav

# Cache/artefatos locais do OmniVoice
.omnivoice/
omnivoice_cache/

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/

# IDEs
.vscode/
.idea/
*.swp

# Diretório temporário de modelos Llama
temp_llama/
