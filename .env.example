# Copie este arquivo para .env e preencha os valores
DISCORD_TOKEN=SEU_TOKEN_AQUI

# Parâmetros opcionais do modelo
# Se não definidos, usa os valores padrão de config.py
LLM_MODEL_PATH=models/texto/TheDrummer_Cydonia-24B-v4.3-IQ3_XXS.gguf
LLM_N_CTX=8192
LLM_MAX_TOKENS=320
LLM_N_GPU_LAYERS=-1
LLM_N_BATCH=2048
LLM_N_UBATCH=512
# Ajuste opcional: deixe vazio para usar automático.
# LLM_N_THREADS=8
# LLM_N_THREADS_BATCH=16
LLM_VOZ_MAX_TOKENS=60
LLM_KV_TYPE=q8_0

# OmniVoice local. Baixe o checkpoint completo para models/omnivoice,
# incluindo a pasta audio_tokenizer. Se vazio, usa k2-fsa/OmniVoice via cache/HF.
OMNIVOICE_MODEL_PATH=models/omnivoice

# Controle de repetição e estilo (ajuste conforme necessário)
LLM_TEMPERATURE=0.85
LLM_REPEAT_PENALTY=1.1
LLM_FREQUENCY_PENALTY=0.1
LLM_PRESENCE_PENALTY=0.1